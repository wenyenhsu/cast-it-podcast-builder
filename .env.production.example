# Production environment — copy to .env.production and update values
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=cast-it.example.com
CSRF_TRUSTED_ORIGINS=https://cast-it.example.com
ENVIRONMENT=production
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_PRELOAD=True

POSTGRES_DB=cast_it
POSTGRES_USER=cast_it
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

BUILD_GIT_COMMIT=local
BUILD_NUMBER=production
BUILD_TIMESTAMP=
APP_VERSION=0.1.0
IMAGE_NAME=cast-it
IMAGE_TAG=latest

LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME=cast-it
ENABLE_METRICS=true
ENABLE_TRACING=true
METRICS_BACKEND=prometheus
TRACING_BACKEND=memory

USE_S3_STORAGE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
AWS_MEDIA_LOCATION=media
AWS_STATIC_LOCATION=static

COLLECT_STATIC_ON_START=true
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
NGINX_HTTP_PORT=80
