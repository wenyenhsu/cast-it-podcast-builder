# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
TIME_ZONE=America/Los_Angeles

# Database
POSTGRES_DB=cast_it
POSTGRES_USER=cast_it
POSTGRES_PASSWORD=cast_it
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Docker Compose (local development)
# WEB_PORT=0 assigns a random host port. Set WEB_PORT=8000 for a stable local URL.
WEB_PORT=8000
# Optional host access for db/redis when using docker-compose.host-access.yml:
# POSTGRES_HOST_PORT=0
# REDIS_HOST_PORT=0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# LLM (Ollama)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=gemma3:12b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60
LLM_RETRY_COUNT=3
LLM_MAX_PROMPT_CHARS=100000

# RAG / Knowledge Base
RAG_ENABLED=true
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.7
RAG_MAX_CONTEXT_TOKENS=4000
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_EMBEDDING_DIMENSIONS=768
RAG_EMBEDDING_BATCH_SIZE=32
RAG_VECTOR_STORE=pgvector
RAG_EMBEDDING_RETRY_COUNT=3

# TTS (Chatterbox — run Chatterbox-TTS-Server on the host; on Apple Silicon use
# PYTORCH_ENABLE_MPS_FALLBACK=1 or set tts_engine.device: cpu in its config.yaml)
TTS_PROVIDER=chatterbox
# Use host.docker.internal when Cast It runs in Docker; localhost if running Django on the host
CHATTERBOX_BASE_URL=http://host.docker.internal:8004
CHATTERBOX_TIMEOUT=120
# Leave empty to auto-pick the first voice from Chatterbox (e.g. Abigail.wav)
CHATTERBOX_DEFAULT_VOICE=
# Optional per-role Chatterbox voice filenames (must exist in Chatterbox voices/)
CHATTERBOX_VOICE_INTRO=
CHATTERBOX_VOICE_EXPERT=
CHATTERBOX_VOICE_BEGINNER=
CHATTERBOX_AUDIO_FORMAT=wav
TTS_MAX_TEXT_LENGTH=5000
TTS_WORDS_PER_MINUTE=150
AUDIO_STORAGE_SUBDIR=audio

# Audio Pipeline (FFmpeg)
AUDIO_OUTPUT_SUBDIR=audio
AUDIO_DEFAULT_BITRATE=192
AUDIO_DEFAULT_SAMPLE_RATE=44100
AUDIO_DEFAULT_SILENCE_SECONDS=0.75
AUDIO_INTRO_FILE_PATH=
AUDIO_OUTRO_FILE_PATH=
AUDIO_BACKGROUND_MUSIC_PATH=
AUDIO_ENABLE_BACKGROUND_MUSIC=false
AUDIO_ENABLE_NORMALIZATION=true
AUDIO_BACKGROUND_MUSIC_VOLUME=0.15
AUDIO_TARGET_LUFS=-16
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
FFMPEG_TIMEOUT=300

# Gmail Newsletter Provider (OAuth2)
# Get credentials from Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_QUERY=label:newsletters is:unread

# Celery Jobs
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300
CELERY_TASK_MAX_RETRIES=3
CELERY_DEFAULT_QUEUE=default
CELERY_RETRY_BASE_DELAY=60
CELERY_RETRY_MAX_DELAY=900
# Comma-separated queues consumed by celery-worker (must match task routing)
CELERY_WORKER_QUEUES=ingestion,llm,tts,audio,publishing,monitoring,celery
BEAT_IMPORT_NEWS_CRON=0 6 * * *
BEAT_EPISODE_PLANNING_CRON=15 6 * * *
# Script generation is manual from /content/ (no beat schedule)
BEAT_GENERATE_AUDIO_CRON=0 7 * * *
BEAT_PUBLISH_EPISODE_CRON=0 10 * * *
BEAT_RETRY_SWEEP_CRON=*/30 * * * *
BEAT_HEALTH_CHECK_CRON=*/15 * * * *

# Observability
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME=cast-it
ENVIRONMENT=development
ENABLE_METRICS=true
ENABLE_TRACING=true
ENABLE_HEALTH_ENDPOINTS=true
REQUEST_ID_HEADER=X-Request-ID
CORRELATION_ID_HEADER=X-Correlation-ID
METRICS_BACKEND=memory
TRACING_BACKEND=memory

# Deployment / Release metadata
APP_VERSION=0.1.0
BUILD_GIT_COMMIT=local
BUILD_NUMBER=local
BUILD_TIMESTAMP=
IMAGE_NAME=cast-it
IMAGE_TAG=local
COLLECT_STATIC_ON_START=true
USE_S3_STORAGE=false

# Publishing
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=
ENABLE_YOUTUBE_PUBLISHING=false
ENABLE_RSS_PUBLISHING=true
RSS_FEED_TITLE=Cast It Podcast
RSS_FEED_SUBTITLE=AI-generated podcast episodes
RSS_FEED_AUTHOR=Cast It
RSS_FEED_LANGUAGE=en-us
RSS_FEED_SITE_URL=https://example.com
RSS_FEED_AUDIO_BASE_URL=https://example.com/media
RSS_FEED_OUTPUT_PATH=feeds/podcast.xml

# Supabase (listener data shelf)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUDIO_BUCKET=episode-audio
BEAT_PUBLISH_SUPABASE_CRON=25 7 * * *
BEAT_GENERATE_SCRIPT_CRON=45 6 * * *
