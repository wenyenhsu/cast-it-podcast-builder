# Staging environment — copy to .env.staging and update values
DJANGO_SETTINGS_MODULE=config.settings.staging
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=staging.example.com,localhost
CSRF_TRUSTED_ORIGINS=https://staging.example.com
ENVIRONMENT=staging
SECURE_SSL_REDIRECT=False

POSTGRES_DB=cast_it_staging
POSTGRES_USER=cast_it
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

BUILD_GIT_COMMIT=local
BUILD_NUMBER=staging
APP_VERSION=0.1.0
IMAGE_TAG=staging

LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME=cast-it
ENABLE_METRICS=true
ENABLE_TRACING=true

USE_S3_STORAGE=false
NGINX_PORT=8080
